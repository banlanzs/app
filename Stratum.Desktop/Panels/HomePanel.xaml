<UserControl x:Class="Stratum.Desktop.Panels.HomePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:Stratum.Desktop.Behaviors"
             xmlns:converters="clr-namespace:Stratum.Desktop.Converters"
             xmlns:vm="clr-namespace:Stratum.Desktop.ViewModels"
             mc:Ignorable="d"
             Background="{StaticResource BgBrush}">

    <UserControl.Resources>
        <converters:IconSizeConverter x:Key="IconSizeConverter"/>

        <!-- Grid Card Template -->
        <DataTemplate x:Key="GridAuthenticatorTemplate">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,12"
                    Cursor="Hand"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="复制验证码" Command="{Binding CopyCodeCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="编辑" Command="{Binding EditAuthenticatorCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="分配分类" Click="AssignCategory_Click"/>
                        <Separator/>
                        <MenuItem Header="显示二维码" Command="{Binding ShowQrCodeCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="删除" Command="{Binding DeleteAuthenticatorCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Foreground="Red"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Icon -->
                    <Border Grid.Column="0" Grid.Row="0" Width="36" Height="36"
                            Background="{StaticResource AccentBrush}" CornerRadius="8"
                            HorizontalAlignment="Left" Margin="0,0,10,0">
                        <Grid>
                            <Image Source="{Binding IconImage}"
                                   Visibility="{Binding IconImage, Converter={StaticResource ImageVisibilityConverter}}"
                                   Width="24" Height="24" Stretch="Uniform"/>
                            <TextBlock Text="{Binding IssuerInitial}" FontSize="18" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding IconImage, Converter={StaticResource ImageVisibilityConverter}, ConverterParameter=Invert}"/>
                        </Grid>
                    </Border>

                    <!-- Service and Account -->
                    <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="{Binding Issuer}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource FgBrush}"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Issuer}"/>
                        <TextBlock Text="{Binding Username}" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Username}"
                                   Visibility="{Binding HasUsername, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Countdown Ring -->
                    <Grid Grid.Column="2" Grid.Row="0" Width="36" Height="36"
                          Visibility="{Binding IsTimeBased, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Ellipse Stroke="{StaticResource BorderBrush}" StrokeThickness="2.5" Width="36" Height="36"/>
                        <Ellipse x:Name="CountdownProgress" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.5"
                                 Width="36" Height="36" RenderTransformOrigin="0.5,0.5"
                                 StrokeDashArray="100 100" StrokeDashOffset="0"/>
                        <TextBlock x:Name="CountdownText" Text="{Binding TimeRemaining, Mode=OneWay}"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Bottom Row: Code + Copy Button -->
                    <Grid Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FormattedCode}" FontSize="28" FontWeight="Bold"
                                       FontFamily="Consolas, SF Mono, Monaco, Courier New"
                                       Foreground="{StaticResource FgBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="工作" FontSize="10" Foreground="{StaticResource MutedBrush}"
                                           Background="#1A6B6B6B" Padding="4,2" Margin="0,0,6,0"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="●"/>
                                    <Run Text="{Binding TimeRemaining, Mode=OneWay, StringFormat={}{0}s}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Width="40" Height="40"
                                Style="{StaticResource CopyButtonStyle}"
                                Click="CopyButton_Click"
                                Tag="{Binding}"
                                ToolTip="复制验证码">
                            <Grid x:Name="CopyButtonGrid">
                                <Path x:Name="CopyIcon" Data="M9 9h13v13H9zM5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                                      Stroke="{StaticResource MutedBrush}" StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform"/>
                                <Path x:Name="CheckIcon" Data="M20 6L9 17l-5-5"
                                      Stroke="{StaticResource SuccessBrush}" StrokeThickness="2.5" Width="18" Height="18" Stretch="Uniform"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- List Row Template -->
        <DataTemplate x:Key="ListAuthenticatorTemplate">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,0,0,8"
                    Cursor="Hand"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="复制验证码" Command="{Binding CopyCodeCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="编辑" Command="{Binding EditAuthenticatorCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="分配分类" Click="AssignCategory_Click"/>
                        <Separator/>
                        <MenuItem Header="显示二维码" Command="{Binding ShowQrCodeCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="删除" Command="{Binding DeleteAuthenticatorCommand}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Foreground="Red"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border Grid.Column="0" Width="32" Height="32"
                            Background="{StaticResource AccentBrush}" CornerRadius="6"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <Grid>
                            <Image Source="{Binding IconImage}"
                                   Visibility="{Binding IconImage, Converter={StaticResource ImageVisibilityConverter}}"
                                   Width="20" Height="20" Stretch="Uniform"/>
                            <TextBlock Text="{Binding IssuerInitial}" FontSize="14" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding IconImage, Converter={StaticResource ImageVisibilityConverter}, ConverterParameter=Invert}"/>
                        </Grid>
                    </Border>

                    <!-- Service and Account -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="{Binding Issuer}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource FgBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Username}" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding HasUsername, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Code -->
                    <TextBlock Grid.Column="2" Text="{Binding FormattedCode}"
                               FontSize="20" FontWeight="Bold"
                               FontFamily="Consolas, SF Mono, Monaco, Courier New"
                               Foreground="{StaticResource FgBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <!-- Category -->
                    <TextBlock Grid.Column="3" Text="工作" FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               Background="#1A6B6B6B" Padding="6,2"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <!-- Timer -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0"
                                Visibility="{Binding IsTimeBased, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                            <Run Text="●"/>
                            <Run Text="{Binding TimeRemaining, Mode=OneWay, StringFormat={}{0}s}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Copy Button -->
                    <Button Grid.Column="5" Width="36" Height="36"
                            Style="{StaticResource CopyButtonStyle}"
                            Click="CopyButton_Click"
                            Tag="{Binding}"
                            ToolTip="复制验证码">
                        <Grid>
                            <Path Data="M9 9h13v13H9zM5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                                  Stroke="{StaticResource MutedBrush}" StrokeThickness="1.8" Width="14" Height="14" Stretch="Uniform"/>
                        </Grid>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <Border Grid.Column="0" MaxWidth="400" HorizontalAlignment="Left"
                        Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0" Data="M11 11a8 8 0 1 1 0-16 8 8 0 0 1 0 16zM21 21l-4.35-4.35"
                              Stroke="{StaticResource MutedBrush}" StrokeThickness="1.8"
                              Width="16" Height="16" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>

                        <TextBox Grid.Column="1" x:Name="SearchTextBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="14" Foreground="{StaticResource FgBrush}"
                                 VerticalAlignment="Center" VerticalContentAlignment="Center"
                                 KeyDown="SearchTextBox_KeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Background="Transparent"
                                                                  BorderThickness="0"
                                                                  IsTabStop="False"
                                                                  VerticalAlignment="Center"/>
                                                    <TextBlock Text="搜索认证器…"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               VerticalAlignment="Center"
                                                               IsHitTestVisible="False"
                                                               Margin="2,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Button Grid.Column="2" x:Name="ClearSearchButton"
                                Style="{StaticResource IconButtonStyle}"
                                Width="24" Height="24" Click="ClearSearchButton_Click"
                                Visibility="{Binding SearchText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                            <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                  Fill="{StaticResource MutedBrush}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Toolbar Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- View Toggle -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="GridViewButton" Style="{StaticResource ViewToggleButtonStyle}"
                                          IsChecked="True" Click="GridViewButton_Click" ToolTip="网格视图">
                                <Path Data="M1 1h6v6H1zM9 1h6v6H9zM1 9h6v6H1zM9 9h6v6H9z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Width="14" Height="14" Stretch="Uniform"/>
                            </ToggleButton>
                            <ToggleButton x:Name="ListViewButton" Style="{StaticResource ViewToggleButtonStyle}"
                                          Click="ListViewButton_Click" ToolTip="列表视图">
                                <Path Data="M1 1h14v3H1zM1 6.5h14v3H1zM1 12h14v3H1z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Width="14" Height="14" Stretch="Uniform"/>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!-- Theme Toggle -->
                    <Button Style="{StaticResource IconButtonStyle}" Width="36" Height="36"
                            Click="ThemeToggleButton_Click" ToolTip="切换主题" Margin="0,0,8,0">
                        <Grid>
                            <Path x:Name="SunIcon" Data="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zM12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
                                  Stroke="{StaticResource MutedBrush}" StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform"/>
                        </Grid>
                    </Button>

                    <!-- Add Button -->
                    <Button Style="{StaticResource AddButtonStyle}" Click="AddButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M7 1v12M1 7h12" Stroke="White" StrokeThickness="2"
                                  Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="添加认证器" Foreground="White" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Authenticator List Area -->
        <Grid Grid.Row="1">
            <!-- Grid View: Virtualized ListBox with UniformGrid layout -->
            <ListBox x:Name="GridItemsControl" ItemsSource="{Binding FilteredAuthenticators}"
                     ItemTemplate="{StaticResource GridAuthenticatorTemplate}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.CacheLength="1,1"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     Padding="24,16,24,24"
                     Visibility="Visible">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="8"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- List View: Virtualized ListBox -->
            <ListBox x:Name="ListItemsControl" ItemsSource="{Binding FilteredAuthenticators}"
                     ItemTemplate="{StaticResource ListAuthenticatorTemplate}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.CacheLength="1,1"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     Padding="24,16,24,24"
                     Visibility="Collapsed">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Empty State -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <Path Data="M11 11a8 8 0 1 1 0-16 8 8 0 0 1 0 16zM21 21l-4.35-4.35"
                      Stroke="{StaticResource MutedBrush}" StrokeThickness="1.5"
                      Width="48" Height="48" Stretch="Uniform" Opacity="0.3"/>
                <TextBlock Text="未找到匹配的认证器" FontSize="14"
                           Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
